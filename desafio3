# ===== DESAFIO 06 - LISTAR 5 NÚMEROS E IMPRIMIR =====

# Exibe o título do programa
print('===== DESAFIO 06 - LISTAR 5 NÚMEROS E IMPRIMIR =====')

# Cria uma lista vazia para armazenar os números
numeros = []

# Entrada de dados: solicita 5 números ao usuário
for i in range(5):
    valor = int(input(f'Digite o {i+1}º número: '))
    numeros.append(valor)  # Adiciona o número à lista

# Saída de dados: imprime cada número separadamente
print('Números digitados:')

for numero in numeros:
    print(numero)
